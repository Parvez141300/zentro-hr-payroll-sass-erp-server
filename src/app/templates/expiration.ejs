<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Subscription Expired</title>
</head>

<body style="margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f7fb;padding:40px 0;">

        <tr>

            <td align="center">

                <table width="650"
                    style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 5px 18px rgba(0,0,0,.08);">

                    <!-- Header -->

                    <tr>

                        <td style="background:#2563eb;padding:35px;text-align:center;">

                            <h1 style="margin:0;color:#fff;font-size:34px;">

                                Zentro

                            </h1>

                            <p style="margin-top:10px;color:#dbeafe;">

                                Modern HR & Payroll ERP Platform

                            </p>

                        </td>

                    </tr>

                    <!-- Body -->

                    <tr>

                        <td style="padding:40px;">

                            <h2 style="margin-top:0;">

                                Hello <%= name %>,

                            </h2>

                            <p style="font-size:16px;color:#4b5563;line-height:1.8;">

                                We hope you're doing well.

                            </p>

                            <p style="font-size:16px;color:#4b5563;line-height:1.8;">

                                Your
                                <strong>Zentro</strong>
                                subscription has expired.

                                Access to premium HR &
                                Payroll ERP features is
                                currently restricted until
                                your subscription is renewed.

                            </p>

                            <table width="100%" cellpadding="0" cellspacing="0"
                                style="margin:30px 0;border-collapse:collapse;">

                                <tr>

                                    <td colspan="2" style="padding:15px;background:#eff6ff;border:1px solid #dbeafe;">

                                        <strong style="font-size:18px;color:#2563eb;">

                                            Subscription
                                            Details

                                        </strong>

                                    </td>

                                </tr>

                                <tr>

                                    <td style="padding:14px;border:1px solid #e5e7eb;width:40%;">

                                        Plan

                                    </td>

                                    <td style="padding:14px;border:1px solid #e5e7eb;">

                                        <strong>
                                            <%= subscriptionPlan %>
                                        </strong>

                                    </td>

                                </tr>

                                <tr>

                                    <td style="padding:14px;border:1px solid #e5e7eb;">

                                        Status

                                    </td>

                                    <td style="padding:14px;border:1px solid #e5e7eb;color:#dc2626;font-weight:bold;">

                                        <%= subscriptionStatus %>

                                    </td>

                                </tr>

                                <tr>

                                    <td style="padding:14px;border:1px solid #e5e7eb;">

                                        Expiration Date

                                    </td>

                                    <td style="padding:14px;border:1px solid #e5e7eb;">

                                        <%= subscriptionExpiry %>

                                    </td>

                                </tr>

                            </table>

                            <p style="font-size:16px;color:#4b5563;line-height:1.8;">

                                To continue using employee
                                management, attendance,
                                leave management, payroll,
                                and reporting features,
                                please renew your
                                subscription.

                            </p>

                            <!-- Button -->

                            <table align="center" cellpadding="0" cellspacing="0" style="margin:35px auto;">

                                <tr>

                                    <td bgcolor="#2563eb" style="border-radius:8px;">

                                        <a href="<%= renewSubscriptionUrl %>"
                                            style="display:inline-block;padding:15px 35px;color:#ffffff;text-decoration:none;font-weight:bold;font-size:16px;">

                                            Renew
                                            Subscription

                                        </a>

                                    </td>

                                </tr>

                            </table>

                            <p style="font-size:15px;color:#6b7280;line-height:1.8;">

                                If you have already renewed
                                your subscription, please
                                ignore this email.

                            </p>

                            <p style="margin-top:35px;font-size:16px;color:#111827;">

                                Regards,

                                <br>

                                <strong>

                                    Zentro Team

                                </strong>

                            </p>

                        </td>

                    </tr>

                    <!-- Footer -->

                    <tr>

                        <td style="background:#f9fafb;padding:25px;text-align:center;border-top:1px solid #e5e7eb;">

                            <p style="margin:0;font-size:14px;color:#6b7280;">

                                Zentro — Modern HR &
                                Payroll ERP Platform

                            </p>

                            <p style="margin-top:10px;font-size:13px;color:#9ca3af;">

                                Employee Management •
                                Attendance • Leave •
                                Payroll • Reports

                            </p>

                            <p style="margin-top:18px;font-size:12px;color:#9ca3af;">

                                © <%= new Date().getFullYear() %>
                                    Zentro. All rights
                                    reserved.

                            </p>

                        </td>

                    </tr>

                </table>

            </td>

        </tr>

    </table>

</body>

</html>