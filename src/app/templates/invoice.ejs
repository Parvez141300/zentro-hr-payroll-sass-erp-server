<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Successful</title>
</head>

<body style="margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f7fb;padding:40px 20px;">
        <tr>
            <td align="center">

                <table width="650" cellpadding="0" cellspacing="0"
                    style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,.08);">

                    <!-- Header -->
                    <tr>
                        <td align="center" style="background:#2563eb;padding:35px 30px;color:#ffffff;">

                            <h1 style="margin:0;font-size:32px;">
                                Zentro
                            </h1>

                            <p style="margin-top:12px;font-size:16px;line-height:26px;">
                                HR & Payroll ERP Platform
                            </p>

                        </td>
                    </tr>

                    <!-- Greeting -->
                    <tr>
                        <td style="padding:40px 40px 20px 40px;">

                            <h2 style="margin:0;color:#1e293b;">
                                Hello <%= customerName %>,
                            </h2>

                            <p style="margin-top:18px;font-size:15px;line-height:28px;color:#475569;">

                                Thank you for choosing
                                <strong>Zentro HR & Payroll ERP.</strong>

                                Your subscription payment has been
                                <strong style="color:#16a34a;">successfully completed.</strong>

                                Your invoice has been generated successfully.

                            </p>

                        </td>
                    </tr>

                    <!-- Invoice Summary -->
                    <tr>
                        <td style="padding:0 40px 10px 40px;">

                            <table width="100%"
                                style="border-collapse:collapse;background:#f8fafc;border:1px solid #e5e7eb;">

                                <tr>
                                    <td style="padding:14px;font-weight:bold;">Invoice ID</td>
                                    <td style="padding:14px;">
                                        <%= invoiceId %>
                                    </td>
                                </tr>

                                <tr style="background:#ffffff;">
                                    <td style="padding:14px;font-weight:bold;">Transaction ID</td>
                                    <td style="padding:14px;">
                                        <%= transactionId %>
                                    </td>
                                </tr>

                                <tr>
                                    <td style="padding:14px;font-weight:bold;">Company</td>
                                    <td style="padding:14px;">
                                        <%= companyName %>
                                    </td>
                                </tr>

                                <tr style="background:#ffffff;">
                                    <td style="padding:14px;font-weight:bold;">Customer</td>
                                    <td style="padding:14px;">
                                        <%= customerName %><br>
                                            <%= customerEmail %>
                                    </td>
                                </tr>

                                <tr>
                                    <td style="padding:14px;font-weight:bold;">Subscription Plan</td>
                                    <td style="padding:14px;">
                                        <strong>
                                            <%= planName %>
                                        </strong>
                                    </td>
                                </tr>

                                <tr style="background:#ffffff;">
                                    <td style="padding:14px;font-weight:bold;">Amount Paid</td>
                                    <td style="padding:14px;">
                                        <strong>$<%= amount %></strong>
                                    </td>
                                </tr>

                                <tr>
                                    <td style="padding:14px;font-weight:bold;">Payment Date</td>
                                    <td style="padding:14px;">
                                        <%= paymentDate %>
                                    </td>
                                </tr>

                            </table>

                        </td>
                    </tr>

                    <!-- Download Button -->
                    <tr>
                        <td align="center" style="padding:35px;">

                            <a href="<%= invoiceUrl %>" style="
                                display:inline-block;
                                background:#2563eb;
                                color:#ffffff;
                                text-decoration:none;
                                padding:16px 34px;
                                border-radius:8px;
                                font-size:16px;
                                font-weight:bold;">

                                Download Invoice

                            </a>

                        </td>
                    </tr>

                    <!-- Info -->
                    <tr>
                        <td style="padding:0 40px 35px 40px;">

                            <p style="font-size:14px;color:#64748b;line-height:26px;">

                                A PDF copy of your invoice is also attached to this email for your records.

                                If you have any questions regarding your payment or subscription,
                                please contact our support team.

                            </p>

                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center" style="background:#0f172a;padding:28px;color:#cbd5e1;">

                            <h3 style="margin:0;color:#ffffff;">
                                Zentro
                            </h3>

                            <p style="margin-top:12px;font-size:14px;line-height:24px;">

                                Modern HR & Payroll ERP Platform

                            </p>

                            <p style="margin-top:20px;font-size:12px;color:#94a3b8;">

                                © <%= new Date().getFullYear() %> Zentro.
                                    All rights reserved.

                            </p>

                        </td>
                    </tr>

                </table>

            </td>
        </tr>
    </table>

</body>

</html>