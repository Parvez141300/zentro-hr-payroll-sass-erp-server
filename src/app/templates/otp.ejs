<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zentro Email Verification</title>
</head>

<body style="margin:0;padding:0;background-color:#f4f6f9;font-family:Arial, Helvetica, sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;">
        <tr>
            <td align="center">

                <table width="600" cellpadding="0" cellspacing="0"
                    style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.08);">

                    <!-- Header -->
                    <tr>
                        <td align="center" style="padding:40px 30px;background:#1f2937;color:#ffffff;">
                            <h1 style="margin:0;font-size:32px;">Zentro</h1>
                            <p style="margin-top:10px;font-size:15px;color:#d1d5db;">
                                Modern HR & Payroll ERP Platform
                            </p>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="padding:40px 40px;color:#374151;">

                            <h2 style="margin-top:0;">
                                Hello <%= name %>,
                            </h2>

                            <p style="font-size:16px;line-height:1.8;">
                                Thank you for using <strong>Zentro</strong>.
                                To continue your request, please use the One-Time Password (OTP) below:
                            </p>

                            <!-- OTP Box -->
                            <div style="
                                margin:35px 0;
                                text-align:center;
                            ">
                                <div style="
                                    display:inline-block;
                                    padding:18px 40px;
                                    background:#f3f4f6;
                                    border:2px dashed #2563eb;
                                    border-radius:10px;
                                    font-size:36px;
                                    font-weight:bold;
                                    letter-spacing:8px;
                                    color:#2563eb;
                                ">
                                    <%= otp %>
                                </div>
                            </div>

                            <p style="font-size:15px;line-height:1.8;">
                                This OTP is valid for <strong>2 minutes</strong>.
                                Please do not share this code with anyone for security reasons.
                            </p>

                            <p style="font-size:15px;line-height:1.8;">
                                If you did not request this verification, you can safely ignore this email.
                            </p>

                            <br>

                            <p>
                                Regards,<br>
                                <strong>Zentro Security Team</strong>
                            </p>

                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center"
                            style="padding:30px;background:#f9fafb;color:#6b7280;font-size:13px;line-height:1.8;">

                            <strong>Zentro</strong><br>

                            Modern HR and Payroll ERP platform designed to centralize employee management,
                            attendance tracking, leave administration, payroll processing, and workforce analytics
                            in a single secure system.

                            <br><br>

                            © <%= new Date().getFullYear() %> Zentro. All rights reserved.

                        </td>
                    </tr>

                </table>

            </td>
        </tr>
    </table>

</body>

</html>